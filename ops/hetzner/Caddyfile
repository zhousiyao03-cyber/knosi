# Knosi reverse proxy — runs as a systemd service on the host.
# Terminates TLS for the public domains and forwards everything to Traefik
# at 127.0.0.1:30080, which then routes into the k3s cluster via Ingress.
#
# Certificates are managed automatically by Caddy via Let's Encrypt.
# Cert state lives under /var/lib/caddy/.local/share/caddy/.
#
# Note: both apex and www are served directly (no redirect). Earlier an
# apex→www 301 redirect broke the MCP streamable transport, because MCP
# clients do not re-POST on 301/302. Keeping both hosts proxied avoids the
# whole redirect class of issues.

knosi.xyz, www.knosi.xyz {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
	}

	reverse_proxy 127.0.0.1:30080 {
		header_up Host {host}
	}
}

k3s.knosi.xyz {
	encode gzip zstd

	reverse_proxy 127.0.0.1:30080 {
		header_up Host {host}
	}
}
